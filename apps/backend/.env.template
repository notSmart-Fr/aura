# Vendure commerce server — copy to apps/backend/.env
# Loaded automatically when you run: pnpm backend:dev

# Postgres (Vendure catalog + vector embeddings column)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=vendure

# Vendure admin login (dev defaults)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# CORS
STORE_CORS=http://localhost:5173
ADMIN_CORS=http://localhost:5173,http://localhost:3000
AUTH_CORS=http://localhost:5173,http://localhost:3000

# Vendure auth secrets
JWT_SECRET=
COOKIE_SECRET=

# Redis (BullMQ + session store — same host worker/voice-agent use)
REDIS_URL=redis://localhost:6379

# Gemini embeddings (backend config.ts — vector plugin / admin tooling)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# WhatsApp webhook verify token (backend vector-search plugin)
WHATSAPP_VERIFY_TOKEN=
