{
  "name": "@dtc/backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only ./src/index.ts",
    "migration:generate": "vendure migration:generate",
    "migration:run": "vendure migration:run",
    "seed": "ts-node ./src/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.3.10",
    "@nestjs/core": "10.3.10",
    "@nestjs/graphql": "12.2.2",
    "@vendure/admin-ui-plugin": "^2.3.4",
    "@vendure/asset-server-plugin": "^2.3.4",
    "@vendure/core": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "graphql": "^16.8.0",
    "graphql-tag": "^2.12.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "0.3.20",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@swc/core": "^1.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}