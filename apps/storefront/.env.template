# Remix storefront + Mastra concierge — copy to apps/storefront/.env
# Loaded automatically when you run: pnpm storefront:dev

NODE_ENV=development

# Vendure Shop API (GraphQL tools + catalog routes)
VENDURE_API_URL=http://localhost:3000/shop-api

# Remix session cookie
SESSION_SECRET=

# Mastra shop agent (OrchestratorService imports this at runtime)
DEEPSEEK_API_KEY=

# Neon Postgres — semantic cache + embedding storage (cache-engine.server.ts)
PAYLOAD_DATABASE_URL=

# WhatsApp inbound webhooks (api.webhook*.ts)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# OpenTelemetry (optional — defaults to localhost collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
