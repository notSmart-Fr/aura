{
  "name": "aura-monorepo",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "check:firewall": "node --no-warnings --experimental-strip-types scripts/ast-firewall.ts",
    "check:firewall:chaos": "node --no-warnings --experimental-strip-types scripts/ast-firewall.ts --chaos",
    "verify-agent": "node --no-warnings --experimental-strip-types scripts/ast-firewall.ts --watch",
    "build": "pnpm run check:firewall && pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront",
    "voice": "tsx scripts/voice-agent.ts dev",
    "worker": "tsx scripts/worker.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "chokidar": "^3.6.0",
    "chokidar-cli": "^3.0.0",
    "prettier": "^3.2.5",
    "ts-morph": "^22.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "turbo": "^2.0.14",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/openai": "^3.0.73",
    "@dtc/ai-core": "workspace:*",
    "@livekit/agents": "^1.4.8",
    "@livekit/agents-plugin-cartesia": "^1.4.8",
    "@livekit/agents-plugin-deepgram": "^1.4.8",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "bullmq": "^4.17.0",
    "ioredis": "^5.11.1",
    "kysely": "^0.26.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "typeorm": "0.3.20",
    "zod": "4.2.0"
  }
}
