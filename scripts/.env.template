# Transport runners (worker + voice-agent) — copy to scripts/.env
# Loaded by scripts/load-env.ts together with apps/backend/.env and apps/storefront/.env
#
# Run from repo root:
#   node --no-warnings --experimental-strip-types scripts/worker.ts
#   node --no-warnings --experimental-strip-types scripts/voice-agent.ts dev

# --- WhatsApp outbound (scripts/worker.ts) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- LiveKit voice room (scripts/voice-agent.ts) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Speech pipeline plugins (scripts/voice-agent.ts) ---
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
